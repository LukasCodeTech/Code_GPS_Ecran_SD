TinyGPSPlus gps; // the TinyGPS++ object

// Variables pour la trajectoire
double reference_lat = 0;
double reference_lng = 0;

const double LONDON_LAT = 51.508131;
const double LONDON_LON = -0.128002;

bool verification = false;
bool reference_initialisee = false; // Etat initial

double distance_total = 0.0;
double variation;

double distance_cumulee = 0.0; // Distance cumulée
const float distance_enregistrement = 20.0; // Distance d'enregistrement en metres 
double ancienne_lat = 0;
double ancienne_lng = 0;
bool premier_point = true;

