}

// Ecriture de la date sur l'écran U8G2
void date()
{
   if (gps.date.isValid() && gps.time.isValid()) // Verification si la date/temps et valide
    {
      verification = true;
      u8g2.clearBuffer(); // Efface le contenu actuel du buffer écran    
      u8g2.setCursor(40, 50);
      u8g2.print(gps.date.year()); // Affiche l'année
      u8g2.print(F("-")); // Affiche séparateur
      u8g2.print(gps.date.month()); // Affiche le mois
      u8g2.print(F("-")); // Affiche séparateur
      u8g2.print(gps.date.day()); // Affiche le jour
      u8g2.print(F(" ")); // Affiche espace
      u8g2.print(gps.time.hour() + 2); // Affiche l'heure (+2 fuseau horaire)
      Serial.println(gps.time.hour() + 2); // Affiche l'heure (+2 fuseau horaire)
      u8g2.print(F(":")); // Affiche séparateur heure
      u8g2.print(gps.time.minute()); // Affiche les minutes
    }  
    //else 
    //{
    //  verification == false; 
    //}
}
void setup()
{
 
  Wire.begin(21, 22); // SDA = Pin21, SCL = Pin22
  u8g2.begin(); // Initialisation de l'écran OLED
  u8g2.enableUTF8Print(); // Permet l'affichage des caractères UTF8 (accents, etc.)
  Serial.begin(9600); // Initialisation du port série à 9600 bauds
  Serial2.begin(GPS_BAUDRATE, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);

  creation_fichier();
  int_fichier(); //apelle de la fonction int_fichier
}
void loop()
{
    affichage_gps_ecran();

    image_erreur();

    // Permet de lire toutes les données disponibles du GPS si valide
    while (Serial2.available())
    {
      gps.encode(Serial2.read()); // Décode chaque caractères reçu
    }

    // Vérification si la nouvelle donnée GPS a été reçu
    if (gps.location.isUpdated()) 
    {
      gps_calcule_distance();

      gps.encode(Serial2.read()); // Décode chaque caractères reçu

      Serial.println();

      Serial.println("GPS UPDATE");

      date();

      u8g2.sendBuffer();
    }

}  
